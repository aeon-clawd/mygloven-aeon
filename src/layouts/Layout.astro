---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body class="bg-[#0A0A14] text-[#EBDECC] min-h-screen font-sans">
		<slot />
	</body>
</html>
<style is:global>
	@import "tailwindcss";
	:root {
		--accent: 139, 92, 246;
		--accent-light: 0, 212, 255;
	}
	html { font-family: system-ui, sans-serif; scroll-behavior: smooth; }
</style>

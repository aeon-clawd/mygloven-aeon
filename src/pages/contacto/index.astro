---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---
<Layout title="Contacto · mygloven">
	<main>
		<Navbar currentPage="/contacto" />

		<section class="min-h-screen pt-24 pb-16 bg-[#fafafa] flex items-center justify-center px-4">
			<div class="w-full max-w-lg">
				<div class="text-center mb-10">
					<h1 class="text-3xl font-black text-[#1a1a2a] mb-3">Habla con el equipo de my'G</h1>
					<p class="text-gray-400 text-sm">Cuéntanos tu proyecto y te respondemos lo antes posible.</p>
				</div>

				<form
					action="https://formsubmit.co/info@mygloven.com"
					method="POST"
					class="bg-white rounded-2xl shadow-md border border-gray-100 p-8 space-y-5"
				>
					<!-- Formsubmit config -->
					<input type="hidden" name="_subject" value="Nuevo mensaje desde mygloven.com" />
					<input type="hidden" name="_captcha" value="false" />
					<input type="hidden" name="_next" value="https://mygloven.com/contacto?enviado=1" />

					<div>
						<label for="name" class="block text-xs font-semibold text-[#1a1a2a] mb-1.5 uppercase tracking-wide">Nombre</label>
						<input
							type="text"
							id="name"
							name="name"
							required
							placeholder="Tu nombre"
							class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-[#1a1a2a] placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#e4665c] focus:border-transparent transition"
						/>
					</div>

					<div>
						<label for="email" class="block text-xs font-semibold text-[#1a1a2a] mb-1.5 uppercase tracking-wide">Correo electrónico</label>
						<input
							type="email"
							id="email"
							name="email"
							required
							placeholder="tu@email.com"
							class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-[#1a1a2a] placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#e4665c] focus:border-transparent transition"
						/>
					</div>

					<div>
						<label for="message" class="block text-xs font-semibold text-[#1a1a2a] mb-1.5 uppercase tracking-wide">Comentario / Mensaje</label>
						<textarea
							id="message"
							name="message"
							required
							rows="5"
							placeholder="Cuéntanos en qué podemos ayudarte..."
							class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-[#1a1a2a] placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#e4665c] focus:border-transparent transition resize-none"
						></textarea>
					</div>

					<button
						type="submit"
						class="w-full bg-[#e4665c] hover:bg-[#d86259] text-white font-bold py-3.5 rounded-xl transition-all text-sm"
					>
						Enviar mensaje →
					</button>
				</form>

				<p class="text-center text-xs text-gray-400 mt-6">
					También puedes escribirnos a <a href="mailto:info@mygloven.com" class="text-[#e4665c] hover:underline">info@mygloven.com</a>
				</p>
			</div>
		</section>

		<Footer />
	</main>
</Layout>

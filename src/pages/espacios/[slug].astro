---
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/CTA.astro";
import {
  getAllVenues,
  getVenueBySlug,
  venueCapacityLabel,
  venueTagLabel,
  pad,
} from "../../lib/queries";

export async function getStaticPaths() {
  const venues = await getAllVenues();
  return venues.map((v, idx) => ({
    params: { slug: v.slug },
    props: { idx },
  }));
}

const { slug } = Astro.params;
const { idx } = Astro.props;
const venue = await getVenueBySlug(slug as string);
if (!venue) return Astro.redirect("/404");

const num = pad((idx ?? 0) + 1);
const tag = venueTagLabel(venue);
const capacity = venueCapacityLabel(venue);
const cityCountry = [venue.ciudad?.trim(), venue.pais?.trim()].filter(Boolean).join(", ");
const galleryImages = venue.images.slice(0, 6);
const totalImages = galleryImages.length;
---
<Layout title={`${venue.nombre} — Espacios MYGLOVEN`} current="espacios">
  <section class="detail-hero">
    <div class="container">
      <a class="detail-back" href="/espacios" data-cursor="volver">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M11 6l-6 6 6 6"/></svg>
        Espacios
      </a>
      <div class="eyebrow">— № {num} · {tag}{venue.ciudad ? ` · ${venue.ciudad.trim()}` : ""}</div>
      <h1>{venue.nombre}<span class="ap">.</span></h1>
      <div class="detail-meta">
        {cityCountry && (
          <div class="item">
            <span class="lbl">CIUDAD</span>
            <span class="val">{cityCountry}</span>
          </div>
        )}
        {capacity && (
          <div class="item">
            <span class="lbl">CAPACIDAD</span>
            <span class="val">{capacity}</span>
          </div>
        )}
        <div class="item">
          <span class="lbl">TIPO</span>
          <span class="val">{tag}</span>
        </div>
        <div class="item">
          <span class="lbl">CÓDIGO</span>
          <span class="val" style="color: var(--color-accent);">№ {num}</span>
        </div>
      </div>
    </div>
  </section>

  {totalImages > 0 && (
    <div class="gallery" style="padding-top: 32px; padding-bottom: 32px;">
      {galleryImages.map((img, i) => (
        <div class="ph" style={`aspect-ratio: 16/10;`}>
          <img src={img.url} alt={img.label || venue.nombre} loading="lazy" />
          <span class="stamp">— {String(i + 1).padStart(2, "0")} / {String(totalImages).padStart(2, "0")}</span>
        </div>
      ))}
    </div>
  )}

  <section class="detail-body">
    <div>
      {venue.descripcion && <p>{venue.descripcion}</p>}
      <p>
        Si te interesa programar un evento aquí, escríbenos y montamos la propuesta en 48 h.
      </p>
      <div style="display: flex; gap: 12px; margin-top: 32px;">
        <a class="btn primary lg" href="/contacto" data-cursor="reservar →">
          Solicitar venue
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        {venue.web && (
          <a class="btn lg" href={venue.web} target="_blank" rel="noopener" data-cursor="web ↗">Web oficial</a>
        )}
      </div>
    </div>
    <aside class="detail-aside">
      <h4>— Datos clave</h4>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        {capacity && (
          <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 11px; padding: 10px 0; border-bottom: 1px solid var(--color-rule);">
            <span style="color: var(--color-text-muted);">AFORO</span>
            <span style="font-weight: 600; color: var(--color-accent);">{capacity}</span>
          </div>
        )}
        {venue.barrio && (
          <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 11px; padding: 10px 0; border-bottom: 1px solid var(--color-rule);">
            <span style="color: var(--color-text-muted);">DISTRITO</span>
            <span style="font-weight: 600;">{venue.barrio}</span>
          </div>
        )}
        {venue.equipo_sonido && (
          <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 11px; padding: 10px 0; border-bottom: 1px solid var(--color-rule);">
            <span style="color: var(--color-text-muted);">SONIDO</span>
            <span style="font-weight: 600;">{venue.equipo_sonido}</span>
          </div>
        )}
        {venue.exterior && (
          <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 11px; padding: 10px 0; border-bottom: 1px solid var(--color-rule);">
            <span style="color: var(--color-text-muted);">EXTERIOR</span>
            <span style="font-weight: 600;">SÍ</span>
          </div>
        )}
        {venue.licencia_musica && (
          <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 11px; padding: 10px 0;">
            <span style="color: var(--color-text-muted);">LIC. MÚSICA</span>
            <span style="font-weight: 600;">SÍ</span>
          </div>
        )}
      </div>

      {(venue.web || venue.instagram || venue.email) && (
        <>
          <h4 style="margin-top: 24px;">— Contacto</h4>
          <div class="platforms">
            {venue.web && (
              <a href={venue.web} target="_blank" rel="noopener" data-cursor="web ↗">
                <span>Web</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M9 7h8v8"/></svg>
              </a>
            )}
            {venue.instagram && (
              <a href={venue.instagram.startsWith("http") ? venue.instagram : `https://instagram.com/${venue.instagram.replace(/^@/, "")}`} target="_blank" rel="noopener" data-cursor="ig ↗">
                <span>Instagram</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M9 7h8v8"/></svg>
              </a>
            )}
            {venue.email && (
              <a href={`mailto:${venue.email}`} data-cursor="email">
                <span>Email</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M9 7h8v8"/></svg>
              </a>
            )}
          </div>
        </>
      )}
    </aside>
  </section>

  {venue.annexes && venue.annexes.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="eyebrow">— Anexos</div>
        <h2 class="h-section">Espacios dentro de {venue.nombre}<span class="ap">.</span></h2>
        <p style="margin: 16px 0 32px; max-width: 60ch; color: var(--color-text-secondary);">
          {venue.nombre} cuenta con {venue.annexes.length} {venue.annexes.length === 1 ? "espacio" : "espacios"} configurables. Cada uno con su propia capacidad y tipo de evento.
        </p>
        <div class="annexes-grid">
          {venue.annexes.map((a) => {
            const cover = a.images?.[0]?.url;
            const capPie = a.config_de_pie ?? 0;
            const capSent = a.config_sentado ?? 0;
            const tipos = (a.tipos_evento || []).slice(0, 3);
            return (
              <article class="annex-card">
                <div class="ph">
                  {cover ? <img src={cover} alt={a.nombre} loading="lazy" /> : <span class="ph-empty">—</span>}
                  {a.tipo_espacio && <span class="annex-tag">{a.tipo_espacio}</span>}
                </div>
                <div class="annex-body">
                  <h3>{a.nombre}<span class="ap">.</span></h3>
                  <div class="annex-meta">
                    {capPie > 0 && (
                      <div class="annex-meta-row">
                        <span class="lbl">DE PIE</span>
                        <span class="val">{capPie} PAX</span>
                      </div>
                    )}
                    {capSent > 0 && (
                      <div class="annex-meta-row">
                        <span class="lbl">SENTADO</span>
                        <span class="val">{capSent} PAX</span>
                      </div>
                    )}
                    {a.metros_cuadrados && (
                      <div class="annex-meta-row">
                        <span class="lbl">SUPERFICIE</span>
                        <span class="val">{a.metros_cuadrados} m²</span>
                      </div>
                    )}
                  </div>
                  {tipos.length > 0 && (
                    <div class="annex-tags">
                      {tipos.map((t) => <span class="annex-pill">{t}</span>)}
                    </div>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <section class="section dark">
    <div class="container" style="text-align: center; max-width: 800px;">
      <div class="eyebrow" style="justify-content: center;">— Reserva tu espacio</div>
      <h2 class="h-section">¿Quieres usar este espacio<span class="ap">?</span></h2>
      <p style="margin: 32px auto 0; max-width: 50ch; color: var(--color-text-secondary); font-size: 17px; line-height: 1.6;">
        Elige un plan y empieza a producir tu evento en {venue.nombre} con la asistencia de my'G.
      </p>
      <a class="btn primary lg" href="/planes" style="margin-top: 32px;" data-cursor="planes →">
        Ver planes
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </section>

  <CTA />
</Layout>

<style>
  .annexes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }
  .annex-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 200ms ease, transform 200ms ease;
  }
  .annex-card:hover { border-color: var(--color-accent); transform: translateY(-3px); }
  .annex-card .ph {
    position: relative;
    aspect-ratio: 16/10;
    background: var(--color-surface-2, var(--color-surface));
    overflow: hidden;
  }
  .annex-card .ph img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .annex-card .ph .ph-empty {
    position: absolute; inset: 0;
    display: grid; place-items: center;
    color: var(--color-text-muted);
    font-family: var(--font-mono); font-size: 24px;
  }
  .annex-tag {
    position: absolute; top: 12px; left: 12px;
    font-family: var(--font-mono); font-size: 9px; font-weight: 600;
    letter-spacing: var(--tracking-extreme); text-transform: uppercase;
    background: var(--color-bg); color: var(--color-text-primary);
    padding: 6px 10px; border-radius: 4px;
  }
  .annex-body { padding: 20px; display: flex; flex-direction: column; gap: 16px; }
  .annex-body h3 {
    font-family: var(--font-display);
    font-size: 22px; font-weight: 600; letter-spacing: -.02em;
    margin: 0;
  }
  .annex-meta { display: flex; flex-direction: column; gap: 0; }
  .annex-meta-row {
    display: flex; justify-content: space-between;
    font-family: var(--font-mono); font-size: 11px;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-rule);
  }
  .annex-meta-row:last-child { border-bottom: none; }
  .annex-meta-row .lbl {
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-extreme);
  }
  .annex-meta-row .val { font-weight: 600; color: var(--color-accent); }
  .annex-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .annex-pill {
    font-family: var(--font-mono); font-size: 10px; font-weight: 600;
    letter-spacing: var(--tracking-extreme); text-transform: uppercase;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 4px 8px; border-radius: 4px;
  }
</style>

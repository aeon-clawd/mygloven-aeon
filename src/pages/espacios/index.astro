---
import Layout from "../../layouts/Layout.astro";
import VenueCard from "../../components/VenueCard.astro";
import CTA from "../../components/CTA.astro";
import { getAllVenues } from "../../lib/queries";

const venues = await getAllVenues();
const cities = Array.from(new Set(venues.map((v) => (v.ciudad || "").trim()).filter(Boolean))).sort();
---
<Layout title="Espacios — MYGLOVEN" current="espacios">
  <section class="detail-hero">
    <div class="container">
      <div class="eyebrow">— Red de espacios · {venues.length} venue{venues.length !== 1 ? "s" : ""}</div>
      <h1>Espacios<span class="ap">.</span></h1>
      <p class="lead" style="margin-top: 32px; max-width: 60ch; font-size: 22px;">
        De club íntimo a anfiteatro al aire libre. Cada venue de la red lo hemos producido al menos una vez.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 48px;" id="venues-section">
    <div class="container">
      <div class="list-head">
        <div class="filters" id="venues-filters">
          <button class="chip active" data-city="todas" data-cursor="filtrar">Todas</button>
          {cities.map((c) => (
            <button class="chip" data-city={c} data-cursor="filtrar">{c}</button>
          ))}
        </div>
        <span class="eyebrow" style="margin: 0;" id="venues-count">
          {venues.length} resultado{venues.length !== 1 ? "s" : ""}
        </span>
      </div>
      <div class="venues-grid" id="venues-grid">
        {venues.map((v, i) => (
          <div data-city={(v.ciudad || "").trim()} data-venue-card>
            <VenueCard venue={v} index={i} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Layout>

<script is:inline>
  (function () {
    const filters = document.getElementById("venues-filters");
    const grid = document.getElementById("venues-grid");
    const count = document.getElementById("venues-count");
    if (!filters || !grid || !count) return;

    filters.addEventListener("click", (e) => {
      const btn = e.target.closest(".chip");
      if (!btn) return;
      const city = btn.dataset.city;
      filters.querySelectorAll(".chip").forEach((c) => c.classList.toggle("active", c === btn));
      let visible = 0;
      grid.querySelectorAll("[data-venue-card]").forEach((card) => {
        const match = city === "todas" || card.dataset.city === city;
        card.style.display = match ? "" : "none";
        if (match) visible++;
      });
      count.textContent = `${visible} resultado${visible !== 1 ? "s" : ""}`;
    });
  })();
</script>

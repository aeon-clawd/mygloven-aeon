---
import Layout from '../../layouts/Layout.astro';
import { getAllVenues } from '../../sanity/queries';

const venues = await getAllVenues();
---
<Layout title="Espacios · mygloven">
	<main>
		<!-- Navbar -->
		<nav class="fixed top-0 w-full z-50 bg-[#1a1a2a] shadow-sm">
			<div class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
				<a href="/" class="text-xl font-light text-white tracking-tight">mygloven.com</a>
				<div class="hidden md:flex items-center gap-6 text-sm">
					<a href="/espacios" class="text-white font-semibold">Espacios</a>
					<a href="/artistas" class="text-gray-300 hover:text-white transition">Artistas</a>
					<a href="/agency" class="text-gray-300 hover:text-white transition">Agency</a>
					<a href="/contacto" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-4 py-1.5 rounded-full text-sm font-semibold transition">Contacto</a>
				</div>
			</div>
		</nav>

		<section class="pt-24 pb-16 bg-[#fafafa]">
			<div class="max-w-7xl mx-auto px-4">
				<div class="text-center mb-14">
					<h1 class="text-3xl font-black text-[#1a1a2a] mb-2">Espacios</h1>
					<p class="text-gray-400 text-sm">{venues.length} espacios registrados</p>
				</div>
				<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">
					{venues.map((venue: any) => {
						const img = venue.images?.[0] || venue.logo;
						const imageUrl = img
							? `https://cdn.sanity.io/images/81mezrx9/production/${img.asset._ref.replace('image-', '').replace(/-([a-z]+)$/, '.$1')}`
							: null;
						return (
							<a href={`/venue/${venue.slug}`} class="group cursor-pointer block bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-gray-100">
								<div class="aspect-video overflow-hidden bg-[#1a1a2a]">
									{imageUrl ? (
										<img
											src={imageUrl}
											alt={venue.name}
											class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
											loading="lazy"
										/>
									) : (
										<div class="w-full h-full flex items-center justify-center">
											<svg class="w-10 h-10 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
											</svg>
										</div>
									)}
								</div>
								<div class="p-3">
									<h3 class="text-[#1a1a2a] font-bold text-sm group-hover:text-[#e4665c] transition-colors line-clamp-1">{venue.name}</h3>
									{venue.city && <p class="text-gray-400 text-[11px] mt-0.5">{venue.city}{venue.country ? `, ${venue.country}` : ''}</p>}
								</div>
							</a>
						);
					})}
				</div>
			</div>
		</section>

		<footer class="py-8 text-center bg-[#fafafa] border-t border-gray-100">
			<div class="flex justify-center gap-4 mb-4">
				<a href="https://www.instagram.com/mygloven/" target="_blank" rel="noopener" class="text-gray-400 hover:text-[#e4665c] transition flex items-center gap-2">
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
					<span class="text-sm">@mygloven</span>
				</a>
			</div>
			<p class="text-[10px] text-gray-400 uppercase tracking-[0.15em]">
				&copy; 2026 MyGloven &bull; Powered by <span class="text-[#e4665c]">Aeon Infinitive</span>
			</p>
		</footer>
	</main>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Página no encontrada · mygloven" description="La página que buscas no existe.">
	<main>
		<Navbar />

		<section class="min-h-[70vh] flex items-center justify-center px-4">
			<div class="text-center">
				<p class="text-8xl font-black text-[#e4665c] mb-4">404</p>
				<h1 class="text-2xl font-black text-[#1a1a2a] mb-3">Página no encontrada</h1>
				<p class="text-gray-400 text-sm mb-8">La página que buscas no existe o ha sido movida.</p>
				<a href="/" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-8 py-3 rounded-full font-bold transition-all text-sm inline-block">
					Volver al inicio →
				</a>
			</div>
		</section>

		<Footer />
	</main>
</Layout>

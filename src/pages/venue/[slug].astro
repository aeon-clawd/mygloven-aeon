---
import Layout from '../../layouts/Layout.astro';
import VenueMap from '../../components/VenueMap';
import venuesData from '../../data/venues.json';

export function getStaticPaths() {
  return venuesData.map((venue: any) => ({
    params: { slug: venue.slug },
    props: { venue },
  }));
}

const { venue } = Astro.props;
const lat = venue.geo?.latitude ? parseFloat(venue.geo.latitude) : null;
const lng = venue.geo?.longitude ? parseFloat(venue.geo.longitude) : null;
const desc = (venue.description || '').replace(/&#039;/g, "'").replace(/&amp;/g, "&").replace(/&nbsp;/g, " ").replace(/\r\n/g, "\n");
const allImages = [...new Set([...(venue.image || []), ...(venue.photo || []), ...(venue.photos || [])])];
const logo = venue.logo?.[0];
const addr = typeof venue.address === 'string' ? venue.address.replace(/&#039;/g, "'") : '';
---

<Layout title={`${venue.name} - MyGloven`}>
  <main class="max-w-5xl mx-auto px-4 py-8">
    <a href="/#explore" class="text-[#e4665c] hover:text-[#d86259] text-sm mb-6 inline-block">← Volver</a>

    <div class="flex items-center gap-4 mb-6">
      {logo && <img src={logo} alt="" class="w-14 h-14 rounded-xl object-cover bg-gray-50 border border-gray-100" />}
      <div>
        <h1 class="text-2xl md:text-3xl font-black text-[#1a1a2a]">{venue.name}</h1>
        <p class="text-gray-400 text-sm mt-1">📍 {addr} {venue.city && `· ${venue.city}`}</p>
      </div>
    </div>

    {allImages.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-8 rounded-xl overflow-hidden">
        <img src={allImages[0]} alt={venue.name} class="w-full h-64 md:h-80 object-cover rounded-xl" />
        {allImages.length > 1 && (
          <div class="grid grid-cols-2 gap-3">
            {allImages.slice(1, 5).map((img: string) => (
              <img src={img} alt={venue.name} class="w-full h-full object-cover rounded-lg" />
            ))}
          </div>
        )}
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="md:col-span-2">
        <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
          <h2 class="text-lg font-bold text-[#1a1a2a] mb-4">Sobre este espacio</h2>
          <div class="text-gray-600 leading-relaxed whitespace-pre-line text-sm">{desc}</div>
        </div>
      </div>

      <div class="space-y-5">
        <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
          <h3 class="font-bold text-[#1a1a2a] mb-4 text-sm uppercase tracking-wider">Contacto</h3>
          <div class="space-y-3 text-sm">
            {venue.telephone && (
              <a href={`tel:${venue.telephone}`} class="flex items-center gap-2 text-gray-500 hover:text-[#e4665c] transition-colors">
                <svg viewBox="0 0 24 24" class="w-4 h-4 fill-gray-400"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                {venue.telephone}
              </a>
            )}
            {venue.email && (
              <a href={`mailto:${venue.email}`} class="flex items-center gap-2 text-gray-500 hover:text-[#e4665c] transition-colors">
                <svg viewBox="0 0 24 24" class="w-4 h-4 fill-gray-400"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                {venue.email}
              </a>
            )}
          </div>
        </div>

        {lat && lng && (
          <VenueMap client:load lat={lat} lng={lng} name={venue.name} address={addr} />
        )}
      </div>
    </div>
  </main>

  <footer class="py-10 text-center border-t border-gray-100 mt-20">
    <p class="text-xs text-gray-400">&copy; 2026 MyGloven &bull; Powered by <span class="text-[#e4665c]">Aeon Infinitive</span></p>
  </footer>
</Layout>

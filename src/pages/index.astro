---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ChatBot from "../components/ChatBot";
import HeroSearch from '../components/HeroSearch';
import ArtistGrid from '../components/ArtistGrid';
import { getAllVenues, getAllArtists, getSiteConfig } from '../sanity/queries';

const venuesData = await getAllVenues();
const artistsData = await getAllArtists();
const config = await getSiteConfig();

const venueCount = venuesData.length;
const artistCount = artistsData.length;
const contactEmail = config?.contactEmail || 'info@mygloven.com';
---
<Layout title="mygloven | myglobalvenue my'G">
	<main>
		<Navbar currentPage="/" />

		<!-- Hero -->
		<section class="relative min-h-[75vh] flex flex-col items-center justify-center text-center px-4 pt-14" 
			style={`background: linear-gradient(rgba(26,26,42,0.65), rgba(26,26,42,0.80)), url('/images/hero-bg.jpg') center/cover no-repeat;`}>
			<div class="relative z-10 max-w-3xl">
				<h1 class="text-4xl md:text-6xl font-extralight text-white mb-4 leading-tight tracking-tight" set:html={config?.heroTitle || 'Espacios y artistas<br>para tu próximo evento.'} />
				<p class="text-base md:text-lg text-white max-w-xl mx-auto mb-8" style="color: #ffffff !important;">
					<span class="text-[#e4665c] font-semibold">{config?.heroHashtag || 'myglobalvenue'}</span><br>
					{config?.heroSubtitle || "new AI tools coming soon.. my'G"}
				</p>

				<!-- Buscador (solo input, sin resultados) -->
				<div class="mt-6 w-full max-w-2xl mx-auto">
					<HeroSearch client:load />
				</div>
			</div>
		</section>

		<!-- Why trust MyGloven -->
		<section class="py-16 bg-white border-b border-gray-100">
			<div class="max-w-5xl mx-auto px-4">
				<h2 class="text-2xl font-black text-[#1a1a2a] mb-10 text-center">¿Por qué confiar en mygloven?</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					{(config?.features || [
						{ title: 'Descubre', description: 'Descubre espacios, artistas y proveedores con una búsqueda inteligente impulsada por IA que te sugiere opciones cercanas y relacionadas para organizar tu evento más fácilmente.' },
						{ title: 'Conecta', description: 'Conecta fácilmente con espacios, artistas, proveedores y profesionales de la industria musical para colaborar, crear oportunidades y hacer realidad tus eventos.' },
						{ title: 'Información clara y útil', description: 'Accede a toda la información necesaria en un solo lugar: riders técnicos, aforos, contactos directos, visualización de espacios y más herramientas para planificar tu evento con claridad.' },
					]).map((f: any, i: number) => (
						<div class="text-center">
							<div class="text-4xl font-black text-[#e4665c] mb-2">{i + 1}</div>
							<h3 class="font-bold text-[#1a1a2a] mb-2">{f.title}</h3>
							<p class="text-sm text-gray-500">{f.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Espacios -->
		<section id="explore" class="py-16 bg-[#fafafa]">
			<div class="max-w-7xl mx-auto px-4 text-center">
				<h2 class="text-3xl font-black text-[#1a1a2a] mb-2">Espacios</h2>
				<p class="text-gray-400 text-sm">Descubre nuevos espacios para tus eventos.</p>
				<p class="text-gray-400 text-xs max-w-2xl mx-auto mt-4 leading-relaxed">
					En mygloven estamos enfocando la plataforma hacia una selección más cuidada de venues. Próximamente trabajaremos principalmente con espacios muy especiales, característicos y polivalentes en Madrid y Barcelona, con información mucho más completa y detallada para facilitar la producción de eventos. Además, mantendremos esta sección aparte con otros espacios compatibles en diferentes ciudades de España.
				</p>
				<div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
					<a href="/espacios" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-8 py-3 rounded-full font-bold transition-all inline-block text-sm">
						Ver todos los espacios →
					</a>
					<a href={`mailto:${contactEmail}`} class="border-2 border-[#e4665c] text-[#e4665c] hover:bg-[#e4665c] hover:text-white px-8 py-3 rounded-full font-bold transition-all inline-block text-sm">
						¿Tienes un espacio? Regístrate →
					</a>
				</div>
			</div>
		</section>

		<!-- Artists -->
		<section id="artists" class="py-20 bg-white border-y border-gray-100">
			<div class="max-w-7xl mx-auto px-4">
				<div class="text-center mb-14">
					<h2 class="text-3xl font-black text-[#1a1a2a] mb-2">Artistas</h2>
					<p class="text-gray-400 text-sm">Descubre nuestros talentos.</p>
				</div>
				<ArtistGrid client:load artists={artistsData} />
				<div class="text-center mt-14 flex flex-col sm:flex-row gap-4 justify-center">
					<a href="/artistas" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-8 py-3 rounded-full font-bold transition-all inline-block text-sm">
						Ver más artistas →
					</a>
					<a href={`mailto:${contactEmail}`} class="border-2 border-[#e4665c] text-[#e4665c] hover:bg-[#e4665c] hover:text-white px-8 py-3 rounded-full font-bold transition-all inline-block text-sm">
						¿Eres artista? Regístrate →
					</a>
				</div>
			</div>
		</section>

		<!-- my'G agency block -->
		<section class="py-20 bg-[#1a1a2a]">
			<div class="max-w-4xl mx-auto px-4 text-center">
				<p class="text-[#e4665c] text-xs font-semibold uppercase tracking-[0.2em] mb-4">Servicio integral</p>
				<h2 class="text-3xl font-black text-white mb-6">my'G <span class="text-[#e4665c]">agency</span></h2>
				<p class="text-gray-300 text-base leading-relaxed max-w-2xl mx-auto mb-10">
					Creamos y producimos eventos de principio a fin. Desde la localización del espacio hasta la producción técnica, logística, coordinación de proveedores o catering. Un servicio 360º para que solo tengas que imaginar el evento.
				</p>
				<a href="/contacto" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-10 py-3.5 rounded-full font-bold inline-block transition-all text-sm">
					Cuéntanos tu evento →
				</a>
			</div>
		</section>

		<!-- About -->
		<section id="about" class="py-16 bg-[#fafafa]">
			<div class="max-w-4xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
				<div>
					<h2 class="text-2xl font-black text-[#1a1a2a] mb-4">About my'G</h2>
					<p class="text-gray-500 leading-relaxed text-sm mb-3">mygloven nace con la misión de facilitar la organización de eventos conectando espacios, artistas, proveedores y promotores en una misma plataforma.</p>
					<p class="text-gray-500 leading-relaxed text-sm mb-3">Estamos desarrollando herramientas de búsqueda inteligente y asistencia con IA para ayudar a descubrir venues, encontrar artistas, recomendar proveedores y planificar eventos de forma más sencilla.</p>
					<p class="text-gray-500 leading-relaxed text-sm">Nuestro objetivo es crear un punto de encuentro donde se integren proyectos y recursos para eventos, reuniendo todo lo necesario en un solo lugar.</p>
				</div>
				<div class="bg-[#1a1a2a] rounded-2xl p-10 text-center">
					<p class="text-3xl font-black text-white mb-2">{config?.primaveraProYear || "Primavera Pro '26"}</p>
					<p class="text-[#e4665c] font-semibold text-sm">{config?.primaveraProSubtitle || 'Proyecto seleccionado · Ideas Showroom'}</p>
					<p class="text-gray-400 text-xs mt-2">{config?.primaveraProDate || 'Barcelona · 3-5 Junio 2026'}</p>
					<a href="https://www.primaverasound.com/en/primavera-pro/meet-the-selected-proposals-for-ideas-showroom-2026" target="_blank" rel="noopener" class="inline-block mt-4 text-[#e4665c] hover:text-white text-xs font-semibold border border-[#e4665c] px-4 py-1.5 rounded-full transition-all hover:bg-[#e4665c]">
						Ver Ideas Showroom →
					</a>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="py-16 bg-[#1a1a2a] text-center">
			<div class="max-w-xl mx-auto px-4">
				<h2 class="text-2xl font-black text-white mb-4">{config?.ctaTitle || '¿Quieres formar parte?'}</h2>
				<p class="text-gray-400 text-sm mb-8">{config?.ctaSubtitle || 'Espacios, artistas y promotores — únete a la comunidad.'}</p>
				<a href="/contacto" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-10 py-3.5 rounded-full font-bold inline-block transition-all text-sm">
					Contactar →
				</a>
			</div>
		</section>

		<!-- Planes CTA -->
		<section class="py-16 bg-[#fafafa] border-t border-gray-100">
			<div class="max-w-3xl mx-auto px-4 text-center">
				<p class="text-[#e4665c] text-xs font-semibold uppercase tracking-[0.2em] mb-3">De explorar a crear</p>
				<h2 class="text-2xl font-black text-[#1a1a2a] mb-4">Planes — Empieza a crear</h2>
				<p class="text-gray-500 text-sm leading-relaxed max-w-xl mx-auto mb-8">
					Elige cómo quieres usar mygloven. Desde explorar gratis hasta producir tu evento con nuestro equipo.
				</p>
				<a href="/planes" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-10 py-3.5 rounded-full font-bold inline-block transition-all text-sm">
					Ver planes →
				</a>
			</div>
		</section>

		<!-- Space Studio teaser -->
		<section class="py-16 bg-white">
			<div class="max-w-3xl mx-auto px-4 text-center">
				<p class="text-[#e4665c] text-xs font-semibold uppercase tracking-[0.2em] mb-3">Próximamente</p>
				<h2 class="text-2xl font-black text-[#1a1a2a] mb-4">my'G <span class="text-[#e4665c]">Space Studio</span></h2>
				<p class="text-gray-500 text-sm leading-relaxed max-w-xl mx-auto mb-8">
					Diseña y visualiza tu evento antes de que suceda. Una herramienta con IA que genera renders, sugiere configuraciones y te ayuda a planificar de forma visual.
				</p>
				<a href="/space-studio" class="border-2 border-[#e4665c] text-[#e4665c] hover:bg-[#e4665c] hover:text-white px-8 py-3 rounded-full font-bold transition-all inline-block text-sm">
					Descubre más →
				</a>
			</div>
		</section>

		<Footer />

		<ChatBot client:load />
	</main>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import CTA from "../components/CTA.astro";
import VenueCard from "../components/VenueCard.astro";
import ArtistRow from "../components/ArtistRow.astro";
import { SITE } from "../data/site";
import { getAllArtistas, getAllVenues } from "../lib/queries";

const [artistas, venues] = await Promise.all([getAllArtistas(), getAllVenues()]);
const featuredArtists = artistas.slice(0, 5);
const featuredVenues = venues.slice(0, 3);
---
<Layout title="MYGLOVEN — Booking, gestión y talento" current="home">
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid">
      <div class="hero-tag">
        <span class="pulse"></span>
        <span>{SITE.hero.hashtag}</span>
        <span>—</span>
        <span>{SITE.hero.activeLabel}</span>
      </div>
      <h1 class="hero-title">
        Booking, gestión<br/>y talento<span class="ap">.</span>
      </h1>
      <p class="lead" style="font-size: 22px; max-width: 70ch;">
        {SITE.hero.subtitle}
      </p>
      <div class="hero-foot">
        <div class="hero-actions">
          <a class="btn primary lg" href="/artistas" data-cursor="ver roster →">
            Ver roster
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="btn lg" href="/contacto" data-cursor="contacto →">Contacto</a>
        </div>
        <div class="hero-stats">
          {SITE.hero.stats.map((s) => (
            <div class="hero-stat">
              <div class="lbl">— {s.lbl}</div>
              <div class="num">{s.num}<span class="ap">{s.suffix}</span></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="clients">
    <span class="lbl">— Han confiado en nosotros</span>
    <div class="clients-row">
      {SITE.clients.map((c) => <span class="client-logo">{c}</span>)}
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="eyebrow">— Por qué confiar en nosotros</div>
      <h2 class="h-section">Cuatro razones,<br/>sin más.</h2>
      <div class="features-grid">
        {SITE.features.map((f, i) => (
          <div class="feature">
            <div class="num">— 0{i + 1} / 0{SITE.features.length}</div>
            <h3>{f.title}</h3>
            <p>{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container">
      <div class="two-col">
        <div>
          <div class="eyebrow">— Quiénes somos</div>
          <h2 class="h-section">Una agencia<br/>operativa<span style="color: var(--color-accent);">.</span></h2>
        </div>
        <div>
          <p>{SITE.about.primary}</p>
          <p style="color: var(--color-text-primary);">{SITE.about.secondary}</p>
          <a class="btn lg" href="/estudio" style="margin-top: 16px;" data-cursor="conoce el estudio →">
            Conoce el estudio
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {featuredArtists.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="list-head">
          <div>
            <div class="eyebrow">— Roster destacado</div>
            <h2 class="h-section">Artistas.</h2>
          </div>
          <a class="btn" href="/artistas" data-cursor="ver todos →">
            Ver todos los artistas
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
        <div class="artists-list">
          {featuredArtists.map((a, i) => <ArtistRow artista={a} index={i} />)}
        </div>
      </div>
    </section>
  )}

  <section class="primavera">
    <div class="container">
      <div class="year">{SITE.primaveraPro.year}<span class="accent">.</span></div>
      <div>
        <div class="lbl">— Primavera Pro</div>
        <h2>{SITE.primaveraPro.subtitle}</h2>
        <div class="date">{SITE.primaveraPro.date}</div>
        <p style="font-size: 17px; color: var(--color-text-secondary); max-width: 50ch; line-height: 1.6;">
          {SITE.primaveraPro.body}
        </p>
        <div style="display: flex; gap: 12px; margin-top: 32px;">
          <a class="btn primary lg" href="/contacto" data-cursor="reunirnos →">
            Pide reunión
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="btn lg" href="/contacto" data-cursor="programa →" style="border-color: rgba(255,255,255,.2); color: rgba(255,255,255,.7);">Ver programa</a>
        </div>
      </div>
    </div>
  </section>

  {featuredVenues.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="list-head">
          <div>
            <div class="eyebrow">— Espacios destacados</div>
            <h2 class="h-section">Espacios.</h2>
          </div>
          <a class="btn" href="/espacios" data-cursor="ver todos →">
            Ver todos los espacios
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
        <div class="venues-grid">
          {featuredVenues.map((v, i) => <VenueCard venue={v} index={i} />)}
        </div>
      </div>
    </section>
  )}

  <CTA />
</Layout>

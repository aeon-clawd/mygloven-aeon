---
import Layout from "../layouts/Layout.astro";
import CTA from "../components/CTA.astro";
import AccentPicker from "../components/AccentPicker.tsx";
import ThemeToggle from "../components/ThemeToggle.tsx";
import VenueCard from "../components/VenueCard.astro";
import { SITE } from "../data/site";
import { getAllVenues } from "../lib/queries";

const venues = await getAllVenues();

function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
function pickRandom(city: string, max: number) {
  const inCity = venues.filter((v) => (v.ciudad || "").trim().toLowerCase() === city.toLowerCase());
  return shuffle(inCity).slice(0, max);
}
const featuredVenues = [...pickRandom("Barcelona", 3), ...pickRandom("Madrid", 3)];
---
<Layout title={`my'G — ${SITE.brandSuffix}`} current="home">
  <!-- HERO 2 COLUMNAS -->
  <section class="hero hero-split">
    <div class="hero-bg"></div>
    <div class="hero-grid hero-split-grid">
      <div class="hero-left">
        <div class="hero-tag">
          <span class="pulse"></span>
          <span>{SITE.hero.hashtag}</span>
          <span>—</span>
          <span>{SITE.hero.activeLabel}</span>
        </div>
        <h1 class="hero-title hero-title-lg">
          {SITE.hero.title}
        </h1>
        <div class="hero-pick">
          <p class="hero-sub">{SITE.hero.subtitle}</p>
          <AccentPicker client:load />
          <ThemeToggle client:load />
        </div>
        <div class="hero-actions">
          <a class="btn primary lg" href={SITE.hero.cta.href} data-cursor={SITE.hero.cta.cursor}>
            {SITE.hero.cta.label}
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="btn lg" href="/planes" data-cursor="planes →">Ver planes</a>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-mockup" aria-hidden="true">
          <div class="hero-mockup-frame">
            <div class="hero-mockup-bar">
              <span class="dot"></span><span class="dot"></span><span class="dot"></span>
              <span class="hero-mockup-url">my'G · Space Studio</span>
            </div>
            <div class="hero-mockup-body">
              <div class="hero-mockup-aside">
                <span class="hero-mockup-label">— Eventos</span>
                <span class="hero-mockup-row active">Showroom · 03 jun</span>
                <span class="hero-mockup-row">Brand party · 14 jun</span>
                <span class="hero-mockup-row">Festival · 22 jul</span>
              </div>
              <div class="hero-mockup-main">
                <span class="hero-mockup-label">— Propuesta</span>
                <div class="hero-mockup-card">
                  <div class="hero-mockup-thumb"></div>
                  <div>
                    <div class="hero-mockup-row strong">Razzmatazz · BCN</div>
                    <div class="hero-mockup-row faded">Capacidad 2.500 · Open air</div>
                  </div>
                </div>
                <div class="hero-mockup-card">
                  <div class="hero-mockup-thumb alt"></div>
                  <div>
                    <div class="hero-mockup-row strong">DJ · TBA</div>
                    <div class="hero-mockup-row faded">Techno · 90 min</div>
                  </div>
                </div>
                <div class="hero-mockup-card">
                  <div class="hero-mockup-thumb"></div>
                  <div>
                    <div class="hero-mockup-row strong">Catering · Mediterráneo</div>
                    <div class="hero-mockup-row faded">300 PAX · cóctel</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <span class="hero-mockup-tag">Mockup · imagen de producto</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CÓMO FUNCIONA -->
  <section class="section" id="como-funciona">
    <div class="container">
      <div class="eyebrow">{SITE.comoFunciona.eyebrow}</div>
      <h2 class="h-section">{SITE.comoFunciona.title}<span style="color: var(--color-accent);">.</span></h2>
      <div class="features-grid" style="grid-template-columns: repeat(3, 1fr);">
        {SITE.comoFunciona.steps.map((s) => (
          <div class="feature">
            <div class="num">— {s.num} / 03</div>
            <h3>{s.title}<span style="color: var(--color-accent);">.</span></h3>
            <p>{s.body}</p>
          </div>
        ))}
      </div>
      <div style="margin-top: 32px;">
        <a class="btn primary lg" href={SITE.comoFunciona.cta.href} data-cursor={SITE.comoFunciona.cta.cursor}>
          {SITE.comoFunciona.cta.label}
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- PLANES CTA (debajo de Cómo funciona) -->
  <section class="section dark">
    <div class="container" style="text-align: center;">
      <div class="eyebrow" style="justify-content: center;">{SITE.planesCTA.eyebrow}</div>
      <h2 class="h-section">{SITE.planesCTA.title}<span style="color: var(--color-accent);">.</span></h2>
      <p style="margin: 32px auto 0; max-width: 60ch; color: var(--color-text-secondary); font-size: 17px; line-height: 1.6;">
        {SITE.planesCTA.body}
      </p>
      <a class="btn primary lg" href={SITE.planesCTA.cta.href} style="margin-top: 32px;" data-cursor={SITE.planesCTA.cta.cursor}>
        {SITE.planesCTA.cta.label}
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </section>

  <!-- ESPACIOS (3 BCN + 3 MAD aleatorios) -->
  {featuredVenues.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="list-head">
          <div>
            <div class="eyebrow">{SITE.espacios.eyebrow}</div>
            <h2 class="h-section">{SITE.espacios.title}<span style="color: var(--color-accent);">.</span></h2>
            <p style="margin-top: 16px; max-width: 60ch; color: var(--color-text-secondary);">{SITE.espacios.subtitle}</p>
          </div>
          <a class="btn" href={SITE.espacios.cta.href} data-cursor={SITE.espacios.cta.cursor}>
            {SITE.espacios.cta.label}
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
        <p style="margin: 0 0 32px; max-width: 75ch; color: var(--color-text-muted); font-size: 15px; line-height: 1.6;">
          {SITE.espacios.body}
        </p>
        <div class="venues-grid">
          {featuredVenues.map((v, i) => <VenueCard venue={v} index={i} />)}
        </div>
      </div>
    </section>
  )}

  <!-- MY'G AGENCY -->
  <section class="section dark">
    <div class="container">
      <div class="two-col">
        <div>
          <div class="eyebrow">{SITE.agency.eyebrow}</div>
          <h2 class="h-section">{SITE.agency.title}<span style="color: var(--color-accent);">.</span></h2>
        </div>
        <div>
          <p style="font-size: 18px; line-height: 1.6;">{SITE.agency.body}</p>
          <a class="btn primary lg" href={SITE.agency.cta.href} style="margin-top: 24px;" data-cursor={SITE.agency.cta.cursor}>
            {SITE.agency.cta.label}
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT my'G + Primavera Pro card -->
  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <div class="eyebrow">{SITE.about.eyebrow}</div>
          <h2 class="h-section">{SITE.about.title}<span style="color: var(--color-accent);">.</span></h2>
          <p style="margin-top: 24px; font-size: 17px; line-height: 1.7; color: var(--color-text-secondary);">
            {SITE.about.body}
          </p>
        </div>
        <div>
          <div class="card-primavera">
            <div class="eyebrow">{SITE.about.card.eyebrow}</div>
            <h3 style="font-family: var(--font-display); font-size: 36px; font-weight: 600; letter-spacing: -.02em; margin: 16px 0 8px;">
              {SITE.about.card.title}<span style="color: var(--color-accent);">.</span>
            </h3>
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: var(--tracking-extreme); color: var(--color-text-muted); margin-bottom: 24px; text-transform: uppercase;">
              {SITE.about.card.meta}
            </div>
            <a class="btn" href={SITE.about.card.cta.href} target="_blank" rel="noopener" data-cursor={SITE.about.card.cta.cursor}>
              {SITE.about.card.cta.label}
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SPACE STUDIO TEASER -->
  <section class="section dark">
    <div class="container">
      <div class="two-col">
        <div>
          <div class="eyebrow">{SITE.spaceStudioTeaser.eyebrow}</div>
          <h2 class="h-section">{SITE.spaceStudioTeaser.title}<span style="color: var(--color-accent);">.</span></h2>
        </div>
        <div>
          <p style="font-size: 18px; line-height: 1.6;">{SITE.spaceStudioTeaser.body}</p>
          <a class="btn primary lg" href={SITE.spaceStudioTeaser.cta.href} style="margin-top: 24px;" data-cursor={SITE.spaceStudioTeaser.cta.cursor}>
            {SITE.spaceStudioTeaser.cta.label}
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</Layout>

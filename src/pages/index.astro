---
import Layout from '../layouts/Layout.astro';
import ChatBot from "../components/ChatBot";
import SearchBox from '../components/SearchBox';
import ArtistGrid from '../components/ArtistGrid';
import { getAllVenues, getAllArtists, getSiteConfig } from '../sanity/queries';

const venuesData = await getAllVenues();
const artistsData = await getAllArtists();
const config = await getSiteConfig();

const venueCount = venuesData.length;
const artistCount = artistsData.length;
const contactEmail = config?.contactEmail || 'info@mygloven.com';
---
<Layout title="MyGloven · Unifying Music Industry">
	<main>
		<!-- Navbar -->
		<nav class="fixed top-0 w-full z-50 bg-[#1a1a2a] shadow-sm">
			<div class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
				<a href="/" class="text-xl font-light text-white tracking-tight">mygloven.com</a>
				<div class="hidden md:flex items-center gap-6 text-sm">
					<a href="#explore" class="text-gray-300 hover:text-white transition">Espacios</a>
					<a href="#artists" class="text-gray-300 hover:text-white transition">Artistas</a>
					<a href="#about" class="text-gray-300 hover:text-white transition">About</a>
					<a href={`mailto:${contactEmail}`} class="bg-[#e4665c] hover:bg-[#d86259] text-white px-4 py-1.5 rounded-full text-sm font-semibold transition">Contacto</a>
				</div>
			</div>
		</nav>

		<!-- Hero -->
		<section class="relative min-h-[75vh] flex flex-col items-center justify-center text-center px-4 pt-14" 
			style={`background: linear-gradient(rgba(26,26,42,0.65), rgba(26,26,42,0.80)), url('${config?.heroBackground || '/images/hero-bg.jpg'}') center/cover no-repeat;`}>
			<div class="relative z-10 max-w-3xl">
				<h1 class="text-4xl md:text-6xl font-light text-white mb-4 leading-tight tracking-tight" set:html={config?.heroTitle || 'Espacios y artistas<br>para tu próximo evento.'} />
				<p class="text-base md:text-lg text-white max-w-xl mx-auto mb-8">
					{config?.heroSubtitle || "new AI tools coming soon.. my'G."}<br>
					<span class="text-[#e4665c] font-semibold">{config?.heroHashtag || '#myglobalvenue'}</span>
				</p>

				<div class="bg-white rounded-2xl shadow-2xl p-6 max-w-2xl mx-auto">
					<div class="flex gap-4 mb-4 justify-center">
						<a href="#explore" class="flex items-center gap-2 bg-[#e4665c] text-white px-5 py-2 rounded-full text-sm font-semibold">
							Espacios <span class="bg-white/20 px-2 py-0.5 rounded-full text-xs">{venueCount}</span>
						</a>
						<a href="#artists" class="flex items-center gap-2 bg-gray-100 text-[#1a1a2a] px-5 py-2 rounded-full text-sm font-semibold hover:bg-gray-200 transition">
							Artistas <span class="bg-[#e4665c]/10 text-[#e4665c] px-2 py-0.5 rounded-full text-xs">{artistCount}</span>
						</a>
					</div>
					<p class="text-gray-400 text-xs">Busca entre {venueCount + artistCount} espacios y artistas verificados</p>
				</div>
			</div>
		</section>

		<!-- Why trust MyGloven -->
		<section class="py-16 bg-white border-b border-gray-100">
			<div class="max-w-5xl mx-auto px-4">
				<h2 class="text-2xl font-black text-[#1a1a2a] mb-10 text-center">¿Por qué confiar en mygloven?</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					{(config?.features || [
						{ title: 'Descubre espacios más rápido', description: 'Búsqueda inteligente con IA para encontrar el espacio perfecto para tu evento.' },
						{ title: 'Conecta con la industria', description: 'Conectamos espacios, artistas y promotores para facilitar la música en vivo.' },
						{ title: 'Información clara y útil', description: 'Rider técnico, capacidad, contacto directo y ubicación exacta en un click.' },
					]).map((f: any, i: number) => (
						<div class="text-center">
							<div class="text-4xl font-black text-[#e4665c] mb-2">{i + 1}</div>
							<h3 class="font-bold text-[#1a1a2a] mb-2">{f.title}</h3>
							<p class="text-sm text-gray-500">{f.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Explore Venues -->
		<section id="explore" class="py-16 bg-[#fafafa]">
			<div class="max-w-7xl mx-auto px-4 text-center mb-8">
				<h2 class="text-3xl font-black text-[#1a1a2a] mb-2">Espacios</h2>
				<p class="text-gray-400 text-sm">Descubre nuevos espacios para tus eventos.</p>
			</div>
			<SearchBox client:load />
			<div class="text-center mt-10">
				<a href={`mailto:${contactEmail}`} class="border-2 border-[#e4665c] text-[#e4665c] hover:bg-[#e4665c] hover:text-white px-8 py-3 rounded-full font-bold transition-all inline-block text-sm">
					¿Tienes un espacio? Regístrate →
				</a>
			</div>
		</section>

		<!-- Artists -->
		<section id="artists" class="py-20 bg-white border-y border-gray-100">
			<div class="max-w-7xl mx-auto px-4">
				<div class="text-center mb-14">
					<h2 class="text-3xl font-black text-[#1a1a2a] mb-2">Artistas</h2>
					<p class="text-gray-400 text-sm">DJs, bandas y productores. Haz click para ver sus perfiles y enlaces.</p>
				</div>
				<ArtistGrid client:load />
				<div class="text-center mt-14 flex flex-col sm:flex-row gap-4 justify-center">
					<a href="/artists" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-8 py-3 rounded-full font-bold transition-all inline-block text-sm">
						Ver más artistas →
					</a>
					<a href={`mailto:${contactEmail}`} class="border-2 border-[#e4665c] text-[#e4665c] hover:bg-[#e4665c] hover:text-white px-8 py-3 rounded-full font-bold transition-all inline-block text-sm">
						¿Eres artista? Regístrate →
					</a>
				</div>
			</div>
		</section>

		<!-- About + Primavera Pro -->
		<section id="about" class="py-16 bg-[#fafafa]">
			<div class="max-w-4xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
				<div>
					<h2 class="text-2xl font-black text-[#1a1a2a] mb-4">Sobre mygloven</h2>
					<p class="text-gray-500 leading-relaxed text-sm mb-3">{config?.aboutText || 'MyGloven nace con una idea sencilla: facilitar la conexión entre espacios, artistas y promotores para hacer posible más eventos de música en vivo.'}</p>
					<p class="text-gray-500 leading-relaxed text-sm">{config?.aboutSecondary || 'Estamos incorporando búsqueda inteligente con IA y herramientas visuales para explorar espacios según la visión de cada evento.'}</p>
				</div>
				<div class="bg-[#1a1a2a] rounded-2xl p-10 text-center">
					<p class="text-3xl font-black text-white mb-2">{config?.primaveraProYear || "Primavera Pro '26"}</p>
					<p class="text-[#e4665c] font-semibold text-sm">{config?.primaveraProSubtitle || 'Proyecto seleccionado · Ideas Showroom'}</p>
					<p class="text-gray-400 text-xs mt-2">{config?.primaveraProDate || 'Barcelona · 3-5 Junio 2026'}</p>
					<a href="https://www.primaverasound.com/es/primavera-pro" target="_blank" rel="noopener" class="inline-block mt-4 text-[#e4665c] hover:text-white text-xs font-semibold border border-[#e4665c] px-4 py-1.5 rounded-full transition-all hover:bg-[#e4665c]">
						Ver Ideas Showroom →
					</a>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="py-16 bg-[#1a1a2a] text-center">
			<div class="max-w-xl mx-auto px-4">
				<h2 class="text-2xl font-black text-white mb-4">{config?.ctaTitle || '¿Quieres formar parte?'}</h2>
				<p class="text-gray-400 text-sm mb-8">{config?.ctaSubtitle || 'Espacios, artistas y promotores — únete a la comunidad.'}</p>
				<a href={`mailto:${contactEmail}`} class="bg-[#e4665c] hover:bg-[#d86259] text-white px-10 py-3.5 rounded-full font-bold inline-block transition-all text-sm">
					{contactEmail}
				</a>
			</div>
		</section>

		<footer class="py-8 text-center bg-[#fafafa] border-t border-gray-100">
			<div class="flex justify-center gap-4 mb-4">
				<a href="https://www.instagram.com/mygloven/" target="_blank" rel="noopener" class="text-gray-400 hover:text-[#e4665c] transition">
					<svg class="w-5 h-5 inline" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
					<span class="ml-1 text-sm">@mygloven</span>
				</a>
			</div>
			<p class="text-[10px] text-gray-400 uppercase tracking-[0.15em]">
				&copy; 2026 MyGloven &bull; Powered by <span class="text-[#e4665c]">Aeon Infinitive</span>
			</p>
		</footer>
	<ChatBot client:load />
	</main>
</Layout>

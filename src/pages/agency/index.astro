---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---
<Layout title="my'G agency · mygloven">
	<main>
		<Navbar currentPage="/agency" />

		<!-- Hero -->
		<section class="pt-32 pb-20 bg-[#1a1a2a] text-center px-4">
			<div class="max-w-3xl mx-auto">
				<p class="text-[#e4665c] text-xs font-semibold uppercase tracking-[0.2em] mb-4">Servicio integral</p>
				<h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">my'G <span class="text-[#e4665c]">agency</span></h1>
				<p class="text-gray-300 text-lg leading-relaxed max-w-2xl mx-auto mb-10">
					Gestionamos y producimos tu evento de principio a fin. Tú imaginas, nosotros lo hacemos realidad.
				</p>
				<a href="/contacto" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-10 py-4 rounded-full font-bold inline-block transition-all text-sm">
					Habla con nuestro equipo →
				</a>
			</div>
		</section>

		<!-- Intro -->
		<section class="py-20 bg-white">
			<div class="max-w-4xl mx-auto px-4 text-center">
				<h2 class="text-2xl font-black text-[#1a1a2a] mb-6">Un servicio 360º para tus eventos</h2>
				<p class="text-gray-500 leading-relaxed text-base max-w-2xl mx-auto">
					my'G agency ofrece un servicio integral de gestión y producción de eventos desde el primer concepto hasta el último detalle. Trabajamos con profesionales especializados en cada área para que tu evento sea exactamente como lo imaginas.
				</p>
			</div>
		</section>

		<!-- Services grid -->
		<section class="py-16 bg-[#fafafa]">
			<div class="max-w-5xl mx-auto px-4">
				<h2 class="text-xl font-black text-[#1a1a2a] mb-10 text-center uppercase tracking-widest text-sm">Nuestros servicios</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
					{[
						{ icon: '📍', title: 'Búsqueda y localización del espacio', desc: 'Encontramos el venue perfecto para tu evento, sea cual sea el formato, el aforo o la ciudad.' },
						{ icon: '🎛️', title: 'Producción técnica', desc: 'Sonido, iluminación, escenografía y todo lo técnico necesario para una experiencia impecable.' },
						{ icon: '🚛', title: 'Logística', desc: 'Coordinamos los tiempos, los traslados y los montajes para que todo fluya sin imprevistos.' },
						{ icon: '🤝', title: 'Coordinación de proveedores', desc: 'Gestionamos todos los proveedores del evento: técnicos, catering, seguridad, mobiliario y más.' },
						{ icon: '📋', title: 'Gestión de permisos', desc: 'Nos encargamos de toda la parte legal y administrativa: licencias, seguros y autorizaciones.' },
						{ icon: '📡', title: 'Streaming y contenido', desc: 'Producción audiovisual y retransmisión en directo para ampliar el alcance de tu evento.' },
						{ icon: '🍽️', title: 'Catering', desc: 'Seleccionamos y coordinamos el servicio gastronómico más adecuado para tu evento y tu audiencia.' },
						{ icon: '✨', title: 'Cualquier otro servicio', desc: 'Cada evento es único. Cuéntanos lo que necesitas y lo integramos en tu propuesta.' },
					].map((service) => (
						<div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-all">
							<div class="text-3xl mb-3">{service.icon}</div>
							<h3 class="font-bold text-[#1a1a2a] text-sm mb-2">{service.title}</h3>
							<p class="text-gray-400 text-xs leading-relaxed">{service.desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- CTA final -->
		<section class="py-20 bg-[#1a1a2a] text-center px-4">
			<div class="max-w-xl mx-auto">
				<h2 class="text-2xl font-black text-white mb-4">¿Tienes un evento en mente?</h2>
				<p class="text-gray-400 text-sm mb-8">Cuéntanos tu proyecto y te diseñamos una propuesta a medida, sin compromiso.</p>
				<a href="/contacto" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-10 py-3.5 rounded-full font-bold inline-block transition-all text-sm">
					Contactar con my'G agency →
				</a>
			</div>
		</section>

		<Footer />
	</main>
</Layout>

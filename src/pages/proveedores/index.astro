---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---
<Layout title="Proveedores · mygloven">
	<main>
		<Navbar currentPage="/proveedores" />

		<!-- Hero -->
		<section class="pt-32 pb-20 bg-[#1a1a2a] text-center px-4">
			<div class="max-w-3xl mx-auto">
				<p class="text-[#e4665c] text-xs font-semibold uppercase tracking-[0.2em] mb-4">Próximamente</p>
				<h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">Proveedores</h1>
				<p class="text-gray-300 text-lg leading-relaxed max-w-2xl mx-auto">
					Próximamente podrás encontrar todo tipo de proveedores para eventos en Madrid y Barcelona: producción técnica, sonido, iluminación, streaming, catering, logística y muchos más servicios necesarios para desarrollar un evento completo.
				</p>
			</div>
		</section>

		<!-- Categorías preview -->
		<section class="py-20 bg-white">
			<div class="max-w-5xl mx-auto px-4">
				<h2 class="text-xl font-black text-[#1a1a2a] mb-10 text-center uppercase tracking-widest text-sm">Categorías que encontrarás</h2>
				<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
					{[
						{ icon: '🎛️', title: 'Producción técnica' },
						{ icon: '🔊', title: 'Sonido' },
						{ icon: '💡', title: 'Iluminación' },
						{ icon: '📡', title: 'Streaming' },
						{ icon: '🍽️', title: 'Catering' },
						{ icon: '🚛', title: 'Logística' },
						{ icon: '🛡️', title: 'Seguridad' },
						{ icon: '✨', title: 'Y mucho más' },
					].map((cat) => (
						<div class="bg-[#fafafa] rounded-xl p-5 text-center border border-gray-100">
							<div class="text-2xl mb-2">{cat.icon}</div>
							<p class="text-sm font-semibold text-[#1a1a2a]">{cat.title}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="py-20 bg-[#1a1a2a] text-center px-4">
			<div class="max-w-xl mx-auto">
				<h2 class="text-2xl font-black text-white mb-4">¿Eres proveedor de eventos?</h2>
				<p class="text-gray-400 text-sm mb-8">Regístrate para aparecer en nuestra plataforma cuando lancemos esta sección.</p>
				<a href="/contacto" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-10 py-3.5 rounded-full font-bold inline-block transition-all text-sm">
					Contactar →
				</a>
			</div>
		</section>

		<Footer />
	</main>
</Layout>

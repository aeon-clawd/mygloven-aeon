---
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/CTA.astro";
import { SITE } from "../../data/site";
---
<Layout title={`Proveedores — ${SITE.brand}`} current="proveedores">
  <section class="detail-hero">
    <div class="container">
      <div class="eyebrow">{SITE.proveedores.eyebrow}</div>
      <h1>{SITE.proveedores.title}<span class="ap">.</span></h1>
      <p class="lead" style="margin-top: 32px; max-width: 60ch; font-size: 22px;">
        {SITE.proveedores.subtitle}
      </p>
      <p style="margin-top: 16px; max-width: 60ch; color: var(--color-text-muted);">
        {SITE.proveedores.body}
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="eyebrow">— Categorías</div>
      <h2 class="h-section" style="margin-bottom: 32px;">Lo que cubriremos<span style="color: var(--color-accent);">.</span></h2>
      <div class="features-grid" style="grid-template-columns: repeat(4, 1fr); gap: 12px;">
        {SITE.proveedores.categorias.map((c, i) => (
          <div class="feature" style="padding: 20px;">
            <div class="num" style="margin-bottom: 8px;">— 0{i + 1}</div>
            <h3 style="font-size: 18px; margin: 0;">{c}<span style="color: var(--color-accent);">.</span></h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container" style="text-align: center; max-width: 900px;">
      <div class="eyebrow" style="justify-content: center;">— Abierto a solicitudes</div>
      <h2 class="h-section">{SITE.proveedores.ctaTitle}</h2>
      <p style="margin: 32px auto 0; max-width: 50ch; color: var(--color-text-secondary); font-size: 17px; line-height: 1.6;">
        {SITE.proveedores.ctaBody}
      </p>
      <form id="proveedor-form" style="margin: 32px auto 0; max-width: 520px; display: flex; flex-direction: column; gap: 12px; text-align: left;">
        <label style="display: flex; flex-direction: column; gap: 6px;">
          <span style="font-family: var(--font-mono); font-size: 10px; font-weight: 700; letter-spacing: var(--tracking-extreme); text-transform: uppercase; color: var(--color-text-muted);">— Nombre o empresa</span>
          <input class="input-field" name="name" required placeholder="Tu nombre o empresa" />
        </label>
        <label style="display: flex; flex-direction: column; gap: 6px;">
          <span style="font-family: var(--font-mono); font-size: 10px; font-weight: 700; letter-spacing: var(--tracking-extreme); text-transform: uppercase; color: var(--color-text-muted);">— Email</span>
          <input class="input-field" type="email" name="email" required placeholder="tu@email.com" />
        </label>
        <label style="display: flex; flex-direction: column; gap: 6px;">
          <span style="font-family: var(--font-mono); font-size: 10px; font-weight: 700; letter-spacing: var(--tracking-extreme); text-transform: uppercase; color: var(--color-text-muted);">— Categoría</span>
          <select class="input-field" name="categoria">
            {SITE.proveedores.categorias.map((c) => <option>{c}</option>)}
          </select>
        </label>
        <label style="display: flex; flex-direction: column; gap: 6px;">
          <span style="font-family: var(--font-mono); font-size: 10px; font-weight: 700; letter-spacing: var(--tracking-extreme); text-transform: uppercase; color: var(--color-text-muted);">— Cuéntanos qué ofreces</span>
          <textarea class="input-field" name="message" rows="4" placeholder="Servicios, ciudad de operación, web o portfolio."></textarea>
        </label>
        <button type="submit" class="btn primary lg" style="margin-top: 8px; justify-content: center;" data-cursor={SITE.proveedores.cta.cursor}>
          {SITE.proveedores.cta.label}
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      </form>
      <div id="proveedor-sent" style="display: none; margin-top: 24px; font-family: var(--font-mono); font-size: 12px; color: var(--color-accent); letter-spacing: var(--tracking-wide); text-transform: uppercase;">
        — Solicitud recibida. Te respondemos en menos de 24 horas.
      </div>
    </div>
  </section>

  <CTA />
</Layout>

<script is:inline>
  (function () {
    const form = document.getElementById("proveedor-form");
    const sent = document.getElementById("proveedor-sent");
    if (!form || !sent) return;
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      // TODO: cablear endpoint (Supabase / email).
      form.style.display = "none";
      sent.style.display = "block";
    });
  })();
</script>

---
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/CTA.astro";
import {
  getAllArtistas,
  getArtistaBySlug,
  artistaDisciplineLabel,
  pad,
} from "../../lib/queries";

export async function getStaticPaths() {
  const artistas = await getAllArtistas();
  return artistas.map((a, idx) => ({
    params: { slug: a.slug },
    props: { idx },
  }));
}

const { slug } = Astro.params;
const { idx } = Astro.props;
const artista = await getArtistaBySlug(slug as string);
if (!artista) return Astro.redirect("/404");

const num = pad((idx ?? 0) + 1);
const discipline = artistaDisciplineLabel(artista);

const platforms = [
  { k: "spotify", l: "Spotify", v: artista.spotify },
  { k: "youtube", l: "YouTube", v: artista.youtube },
  { k: "soundcloud", l: "SoundCloud", v: artista.soundcloud },
  { k: "instagram", l: "Instagram", v: artista.instagram },
  { k: "linktree", l: "Linktree", v: artista.linktree },
  { k: "web", l: "Web oficial", v: artista.web },
].filter((p) => Boolean(p.v));

function platformHref(k: string, v: string): string {
  if (v.startsWith("http")) return v;
  if (k === "instagram") return `https://instagram.com/${v.replace(/^@/, "")}`;
  return v;
}

const galleryImages = artista.images.slice(0, 6);
const totalImages = galleryImages.length;
---
<Layout title={`${artista.nombre} — Artistas MYGLOVEN`} current="artistas">
  <section class="detail-hero">
    <div class="container">
      <a class="detail-back" href="/artistas" data-cursor="volver">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M11 6l-6 6 6 6"/></svg>
        Roster
      </a>
      <div class="eyebrow">— № {num} · {discipline}</div>
      <h1>{artista.nombre}<span class="ap">.</span></h1>
      <div class="detail-meta">
        <div class="item">
          <span class="lbl">DISCIPLINA</span>
          <span class="val">{discipline}</span>
        </div>
        <div class="item">
          <span class="lbl">CÓDIGO</span>
          <span class="val" style="color: var(--color-accent);">№ {num}</span>
        </div>
        <div class="item">
          <span class="lbl">DISPONIBILIDAD</span>
          <span class="val">Activa · 2026</span>
        </div>
        {artista.verificado && (
          <div class="item">
            <span class="lbl">ESTADO</span>
            <span class="val" style="color: var(--color-success);">VERIFICADO</span>
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="detail-body">
    <div>
      {artista.bio && <p>{artista.bio}</p>}
      <p>
        Para booking, riders, fechas internacionales y cuestiones de management, escribe directamente a la agencia. Respondemos en 24 h hábiles.
      </p>
      <div style="display: flex; gap: 12px; margin-top: 32px;">
        <a class="btn primary lg" href="/contacto" data-cursor="contratar →">
          Contratar
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        {artista.rider && (
          <a class="btn lg" href={artista.rider} target="_blank" rel="noopener" data-cursor="rider">Descargar rider</a>
        )}
      </div>
    </div>
    <aside class="detail-aside">
      <h4>— Plataformas</h4>
      <div class="platforms">
        {platforms.length === 0 && (
          <div style="font-family: var(--font-mono); font-size: 11px; color: var(--color-text-muted);">Próximamente</div>
        )}
        {platforms.map((p) => (
          <a href={platformHref(p.k, p.v as string)} target="_blank" rel="noopener" data-cursor="abrir ↗">
            <span>{p.l}</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M9 7h8v8"/></svg>
          </a>
        ))}
      </div>
    </aside>
  </section>

  {totalImages > 0 && (
    <div class="gallery">
      {galleryImages.map((img, i) => (
        <div class="ph">
          <img src={img.url} alt={img.label || artista.nombre} loading="lazy" />
          <span class="stamp">— {String(i + 1).padStart(2, "0")} / {String(totalImages).padStart(2, "0")}</span>
        </div>
      ))}
    </div>
  )}

  <CTA />
</Layout>

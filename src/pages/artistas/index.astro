---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SearchBox from '../../components/SearchBox';
import { getAllArtists } from '../../sanity/queries';

const artists = await getAllArtists();

// Map artists to the same shape SearchBox expects
const artistsAsVenues = artists.map((a: any) => ({
	_id: a._id,
	name: a.name,
	slug: a.slug,
	description: a.description,
	city: '',
	country: '',
	telephone: a.telephone,
	email: a.email,
	logo: null,
	avatar: a.avatar,
	images: a.avatar ? [{ url: a.avatar }] : [],
}));
---
<Layout title="Artistas · mygloven">
	<main>
		<Navbar currentPage="/artistas" />

		<section class="pt-24 pb-16 bg-[#fafafa]">
			<div class="max-w-7xl mx-auto px-4">
				<div class="text-center mb-8">
					<h1 class="text-3xl font-black text-[#1a1a2a] mb-2">Artistas</h1>
					<p class="text-gray-400 text-sm">{artists.length} artistas registrados</p>
				</div>
				<SearchBox client:load venues={artistsAsVenues} searchType="artist" />
			</div>
		</section>

		<Footer />
	</main>
</Layout>

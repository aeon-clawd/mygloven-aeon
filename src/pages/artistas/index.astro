---
import Layout from "../../layouts/Layout.astro";
import ArtistRow from "../../components/ArtistRow.astro";
import CTA from "../../components/CTA.astro";
import { getAllArtistas, artistaDisciplineLabel } from "../../lib/queries";

const artistas = await getAllArtistas();
const disciplineKeys = ["DJ", "Banda", "Cantante", "Cuerda"];
---
<Layout title="Artistas — MYGLOVEN" current="artistas">
  <section class="detail-hero">
    <div class="container">
      <div class="eyebrow">— Roster · {artistas.length} artista{artistas.length !== 1 ? "s" : ""}</div>
      <h1>Artistas<span class="ap">.</span></h1>
      <p class="lead" style="margin-top: 32px; max-width: 60ch; font-size: 22px;">
        DJs, bandas y formaciones en directo. Cada nombre pasa por un filtro propio — presencia, encaje y solidez en directo.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 48px;">
    <div class="container">
      <div class="list-head">
        <div class="filters" id="artists-filters">
          <button class="chip active" data-q="todos" data-cursor="filtrar">Todos</button>
          {disciplineKeys.map((k) => (
            <button class="chip" data-q={k.toLowerCase()} data-cursor="filtrar">{k}s</button>
          ))}
        </div>
        <span class="eyebrow" style="margin: 0;" id="artists-count">
          {artistas.length} resultado{artistas.length !== 1 ? "s" : ""}
        </span>
      </div>
      <div class="artists-list" id="artists-list">
        {artistas.map((a, i) => (
          <div data-disc={artistaDisciplineLabel(a).toLowerCase()} data-artist-row>
            <ArtistRow artista={a} index={i} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Layout>

<script is:inline>
  (function () {
    const filters = document.getElementById("artists-filters");
    const list = document.getElementById("artists-list");
    const count = document.getElementById("artists-count");
    if (!filters || !list || !count) return;

    filters.addEventListener("click", (e) => {
      const btn = e.target.closest(".chip");
      if (!btn) return;
      const q = btn.dataset.q;
      filters.querySelectorAll(".chip").forEach((c) => c.classList.toggle("active", c === btn));
      let visible = 0;
      list.querySelectorAll("[data-artist-row]").forEach((row) => {
        const match = q === "todos" || (row.dataset.disc || "").includes(q);
        row.style.display = match ? "" : "none";
        if (match) visible++;
      });
      count.textContent = `${visible} resultado${visible !== 1 ? "s" : ""}`;
    });
  })();
</script>

---
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/CTA.astro";
import { SITE } from "../../data/site";
---
<Layout title={`Planes — ${SITE.brand}`} current="planes">
  <section class="detail-hero">
    <div class="container">
      <div class="eyebrow">{SITE.planes.eyebrow}</div>
      <h1>{SITE.planes.title}<span class="ap">.</span></h1>
      <p class="lead" style="margin-top: 32px; max-width: 70ch; font-size: 22px;">
        {SITE.planes.body}
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 48px;">
    <div class="container">
      <div class="features-grid" style="grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 0;">
        {SITE.planes.items.map((p) => (
          <div class="feature" style={p.primary ? "background: var(--color-surface-2); border-color: var(--color-accent);" : undefined}>
            <div class="num">— {p.num} / 0{SITE.planes.items.length}</div>
            <h3 style={p.primary ? "color: var(--color-accent); font-size: 28px;" : "font-size: 28px;"}>
              {p.name}<span style="color: var(--color-accent);">.</span>
            </h3>
            <div style="font-family: var(--font-display); font-size: 32px; font-weight: 700; letter-spacing: -.02em; margin: 12px 0 4px;">
              {p.price}<span style="font-size: 14px; font-weight: 400; color: var(--color-text-muted);">{p.period}</span>
            </div>
            <div style="font-family: var(--font-mono); font-size: 10px; font-weight: 600; letter-spacing: var(--tracking-extreme); text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 20px;">
              — {p.para}
            </div>
            <ul style="list-style: none; margin: 0 0 24px; padding: 0; display: flex; flex-direction: column; gap: 8px;">
              {p.features.map((f) => (
                <li style="font-size: 13px; line-height: 1.5; display: flex; gap: 10px; align-items: flex-start; color: var(--color-text-secondary);">
                  <span style="font-family: var(--font-mono); font-weight: 700; color: var(--color-accent); flex-shrink: 0;">+</span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <a class={`btn lg${p.primary ? " primary" : ""}`} href={p.cta.href} style="width: 100%; justify-content: center;" data-cursor={p.cta.cursor}>
              {p.cta.label}
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container" style="text-align: center; max-width: 900px;">
      <div class="eyebrow" style="justify-content: center;">— Recomendación</div>
      <h2 class="h-section">{SITE.planes.ctaTitle}<span style="color: var(--color-accent);">.</span></h2>
      <p style="margin: 32px auto 0; max-width: 50ch; color: var(--color-text-secondary); font-size: 17px; line-height: 1.6;">
        {SITE.planes.ctaBody}
      </p>
      <a class="btn primary lg" href={SITE.planes.cta.href} style="margin-top: 32px;" data-cursor={SITE.planes.cta.cursor}>
        {SITE.planes.cta.label}
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </section>

  <CTA />
</Layout>

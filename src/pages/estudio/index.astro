---
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/CTA.astro";
import { SITE } from "../../data/site";
---
<Layout title="Estudio — MYGLOVEN" current="estudio">
  <section class="detail-hero">
    <div class="container">
      <div class="eyebrow">— Sobre nosotros</div>
      <h1>Estudio<span class="ap">.</span></h1>
      <p class="lead" style="margin-top: 32px; max-width: 70ch; font-size: 24px;">
        Una agencia operativa de booking y management. Equipo pequeño, A&R activo, contratos legibles, tarifas claras.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <div class="eyebrow">— Cómo trabajamos</div>
          <h2 class="h-section">El sistema<br/>operativo<span style="color: var(--color-accent);">.</span></h2>
        </div>
        <div>
          <p>{SITE.about.primary}</p>
          <p style="color: var(--color-text-primary);">{SITE.about.secondary}</p>
          <p>El sistema operativo interno — que llamamos my'G — gestiona desde el primer briefing hasta la facturación post-evento. Cada cliente, productor, espacio y artista tiene su panel.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container">
      <div class="eyebrow">— Equipo</div>
      <h2 class="h-section" style="margin-bottom: 48px;">Quién está detrás<span style="color: var(--color-accent);">.</span></h2>
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px;">
        {SITE.team.map((p) => (
          <div style="background: var(--color-background); padding: 24px; border: 1px solid var(--color-border); border-radius: 4px;">
            <div style="aspect-ratio: 1/1; margin-bottom: 16px; background: linear-gradient(135deg, color-mix(in oklab, var(--color-accent) 15%, #1a1a1a), #0a0a0a); border-radius: 4px; position: relative;">
              <span style="position: absolute; top: 12px; left: 14px; font-family: var(--font-mono); font-size: 10px; font-weight: 600; letter-spacing: var(--tracking-extreme); color: var(--color-text-muted);">№ {p.num}</span>
            </div>
            <div style="font-family: var(--font-display); font-size: 22px; font-weight: 600; letter-spacing: -.02em; margin-bottom: 4px;">{p.name}</div>
            <div style="font-family: var(--font-mono); font-size: 10px; font-weight: 600; letter-spacing: var(--tracking-extreme); text-transform: uppercase; color: var(--color-text-muted);">— {p.role}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Layout>

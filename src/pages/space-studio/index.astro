---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="my'G Space Studio · mygloven">
	<main>
		<!-- Navbar -->
		<nav class="fixed top-0 w-full z-50 bg-[#1a1a2a] shadow-sm">
			<div class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
				<a href="/" class="text-xl font-light text-white tracking-tight">mygloven.com</a>
				<div class="hidden md:flex items-center gap-6 text-sm">
					<a href="/espacios" class="text-gray-300 hover:text-white transition">Espacios</a>
					<a href="/artistas" class="text-gray-300 hover:text-white transition">Artistas</a>
					<a href="/agency" class="text-gray-300 hover:text-white transition">Agency</a>
					<a href="/proveedores" class="text-gray-300 hover:text-white transition">Proveedores</a>
					<a href="/contacto" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-4 py-1.5 rounded-full text-sm font-semibold transition">Contacto</a>
				</div>
				<button id="mobile-menu-btn" class="md:hidden text-white focus:outline-none" aria-label="Menú">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
				</button>
			</div>
			<div id="mobile-menu" class="hidden md:hidden bg-[#1a1a2a] border-t border-gray-700 px-4 pb-4">
				<a href="/espacios" class="block py-3 text-gray-300 hover:text-white transition text-sm border-b border-gray-700/50">Espacios</a>
				<a href="/artistas" class="block py-3 text-gray-300 hover:text-white transition text-sm border-b border-gray-700/50">Artistas</a>
				<a href="/agency" class="block py-3 text-gray-300 hover:text-white transition text-sm border-b border-gray-700/50">my'G agency</a>
				<a href="/proveedores" class="block py-3 text-gray-300 hover:text-white transition text-sm border-b border-gray-700/50">Proveedores</a>
				<a href="/contacto" class="block py-3 text-[#e4665c] font-semibold text-sm">Contacto</a>
			</div>
		</nav>
		<script>
			document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
				document.getElementById('mobile-menu')?.classList.toggle('hidden');
			});
		</script>

		<!-- Hero -->
		<section class="pt-32 pb-20 bg-[#1a1a2a] text-center px-4">
			<div class="max-w-3xl mx-auto">
				<p class="text-[#e4665c] text-xs font-semibold uppercase tracking-[0.2em] mb-4">Próximamente</p>
				<h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">my'G <span class="text-[#e4665c]">Space Studio</span></h1>
				<p class="text-gray-300 text-xl leading-relaxed max-w-2xl mx-auto">
					Diseña y visualiza tu evento antes de que suceda.
				</p>
			</div>
		</section>

		<!-- Descripción -->
		<section class="py-20 bg-white">
			<div class="max-w-3xl mx-auto px-4">
				<p class="text-gray-600 text-base leading-relaxed mb-6">
					my'G Space Studio será una herramienta impulsada por inteligencia artificial que permitirá imaginar cómo podría ser un evento dentro de cualquier espacio.
				</p>
				<p class="text-gray-600 text-base leading-relaxed mb-6">
					Los usuarios podrán subir una foto de un venue o seleccionar uno de la plataforma, describir el tipo de evento que quieren crear y la IA generará diferentes renders y configuraciones posibles, como escenarios, iluminación, distribución del público o producción técnica.
				</p>
				<p class="text-gray-600 text-base leading-relaxed">
					Además, el sistema podrá sugerir artistas, proveedores y soluciones técnicas compatibles con ese espacio, ayudando a planificar eventos de forma más visual, rápida y creativa.
				</p>
			</div>
		</section>

		<!-- Features preview -->
		<section class="py-16 bg-[#fafafa]">
			<div class="max-w-5xl mx-auto px-4">
				<h2 class="text-xl font-black text-[#1a1a2a] mb-10 text-center uppercase tracking-widest text-sm">Qué podrás hacer</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
					{[
						{ icon: '📸', title: 'Sube una foto del espacio', desc: 'Carga una imagen de cualquier venue o selecciona uno de la plataforma como punto de partida.' },
						{ icon: '🎨', title: 'Genera renders con IA', desc: 'Describe tu evento y obtén visualizaciones de escenarios, iluminación y distribución del público.' },
						{ icon: '🤖', title: 'Sugerencias inteligentes', desc: 'Recibe recomendaciones de artistas, proveedores y soluciones técnicas compatibles con el espacio.' },
					].map((f) => (
						<div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm">
							<div class="text-3xl mb-3">{f.icon}</div>
							<h3 class="font-bold text-[#1a1a2a] text-sm mb-2">{f.title}</h3>
							<p class="text-gray-400 text-xs leading-relaxed">{f.desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="py-20 bg-[#1a1a2a] text-center px-4">
			<div class="max-w-xl mx-auto">
				<h2 class="text-2xl font-black text-white mb-4">¿Quieres ser de los primeros en probarlo?</h2>
				<p class="text-gray-400 text-sm mb-8">Déjanos tu contacto y te avisaremos cuando esté disponible.</p>
				<a href="/contacto" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-10 py-3.5 rounded-full font-bold inline-block transition-all text-sm">
					Contactar →
				</a>
			</div>
		</section>

		<footer class="py-8 text-center bg-[#1a1a2a] border-t border-gray-700">
			<div class="flex justify-center gap-4 mb-4">
				<a href="https://www.instagram.com/mygloven/" target="_blank" rel="noopener" class="text-white hover:text-[#e4665c] transition flex items-center gap-2">
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
					<span class="text-sm">@mygloven</span>
				</a>
			</div>
			<p class="text-[10px] text-gray-400 uppercase tracking-[0.15em]">
				&copy; 2026 MyGloven &bull; Powered by <span class="text-[#e4665c]">Aeon Infinitive</span>
			</p>
		</footer>
	</main>
</Layout>

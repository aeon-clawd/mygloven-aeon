---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---
<Layout title="my'G Space Studio · mygloven">
	<main>
		<Navbar currentPage="/space-studio" />

		<!-- Hero -->
		<section class="pt-32 pb-20 bg-[#1a1a2a] text-center px-4">
			<div class="max-w-3xl mx-auto">
				<h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">my'G <span class="text-[#e4665c]">Space Studio</span></h1>
				<p class="text-gray-300 text-xl leading-relaxed max-w-2xl mx-auto">
					Diseña tu evento antes de producirlo
				</p>
				<p class="text-gray-400 text-sm mt-4 max-w-xl mx-auto">
					Visualiza cualquier evento en segundos con IA. Sube un espacio, describe tu idea y obtén una versión real de cómo podría suceder.
				</p>
			</div>
		</section>

		<!-- Storytelling visual: 3 steps -->
		<section class="py-20 bg-white">
			<div class="max-w-6xl mx-auto px-4">

				<!-- Sube tu espacio -->
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-24">
					<div>
						<img src="/images/space-studio-step1.png" alt="my'G Space Studio — sube tu espacio" class="rounded-2xl shadow-lg w-full" loading="lazy" />
					</div>
					<div>
						<h2 class="text-2xl font-black text-[#1a1a2a] mb-4">Sube tu espacio</h2>
						<p class="text-gray-500 text-sm leading-relaxed mb-3">
							Todo evento empieza con un lugar.
						</p>
						<p class="text-gray-500 text-sm leading-relaxed">
							Una nave industrial, una terraza, un salón clásico o cualquier espacio que imagines. Sube una imagen real y conviértela en el punto de partida de tu evento.
						</p>
					</div>
				</div>

				<!-- Describe tu visión -->
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-24">
					<div class="order-2 md:order-1">
						<h2 class="text-2xl font-black text-[#1a1a2a] mb-4">Describe tu visión</h2>
						<p class="text-gray-500 text-sm leading-relaxed mb-3">
							Selecciona la zona que quieres transformar y describe lo que imaginas: mesas de cóctel, escenario, iluminación cálida, branding, pista de baile…
						</p>
						<p class="text-gray-500 text-sm leading-relaxed">
							La IA interpreta tu idea y la aplica directamente sobre el espacio real. No son renders genéricos — es tu evento, en tu venue.
						</p>
					</div>
					<div class="order-1 md:order-2">
						<img src="/images/space-studio-step2.png" alt="my'G Space Studio — describe tu visión" class="rounded-2xl shadow-lg w-full" loading="lazy" />
					</div>
				</div>

				<!-- Tu evento cobra vida -->
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
					<div>
						<img src="/images/space-studio-step3.png" alt="my'G Space Studio — resultado generado" class="rounded-2xl shadow-lg w-full" loading="lazy" />
					</div>
					<div>
						<h2 class="text-2xl font-black text-[#1a1a2a] mb-4">Tu evento cobra vida</h2>
						<p class="text-gray-500 text-sm leading-relaxed mb-3">
							En segundos obtienes una visualización realista. Se respetan las proporciones, la luz y la arquitectura del espacio. Solo cambia lo que tú decides.
						</p>
						<p class="text-gray-500 text-sm leading-relaxed">
							Comparte, ajusta o úsalo como base para producción real.
						</p>
					</div>
				</div>

			</div>
		</section>

		<!-- Before / After comparison -->
		<section class="py-16 bg-[#fafafa]">
			<div class="max-w-5xl mx-auto px-4">
				<h2 class="text-xl font-black text-[#1a1a2a] mb-10 text-center">Antes y después</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<div class="relative aspect-[3/2]">
						<img src="/images/space-before-opt.jpg" alt="Antes — espacio vacío" class="rounded-2xl w-full h-full object-cover" loading="lazy" />
						<span class="absolute top-4 left-4 bg-[#1a1a2a]/80 text-white text-xs font-bold px-3 py-1 rounded-full">Antes</span>
					</div>
					<div class="relative aspect-[3/2]">
						<img src="/images/space-after.jpg" alt="Después — evento visualizado con IA" class="rounded-2xl w-full h-full object-cover" loading="lazy" />
						<span class="absolute top-4 left-4 bg-[#e4665c]/90 text-white text-xs font-bold px-3 py-1 rounded-full">Después</span>
					</div>
				</div>
				<p class="text-gray-400 text-xs text-center mt-4">Ejemplo generado con 6 mesas de cóctel y un escenario pequeño</p>
			</div>
		</section>

		<!-- De idea a producción -->
		<section class="py-20 bg-white">
			<div class="max-w-3xl mx-auto px-4 text-center">
				<h2 class="text-2xl font-black text-[#1a1a2a] mb-6">De idea a producción</h2>
				<p class="text-gray-500 text-sm leading-relaxed max-w-xl mx-auto">
					Space Studio no es solo visual. Es el primer paso para producir tu evento: validar ideas, alinear equipos y tomar decisiones antes de invertir.
				</p>
			</div>
		</section>

		<!-- Potential / Roadmap -->
		<section class="py-20 bg-[#fafafa]">
			<div class="max-w-3xl mx-auto px-4 text-center">
				<p class="text-[#e4665c] text-xs font-semibold uppercase tracking-[0.2em] mb-4">Esto es solo el principio</p>
				<h2 class="text-2xl font-black text-[#1a1a2a] mb-10">Una primera versión de algo mucho más grande</h2>
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-left max-w-2xl mx-auto">
					<div class="bg-white rounded-xl p-5 border border-gray-100">
						<p class="text-[#e4665c] text-xs font-bold mb-2">AHORA</p>
						<p class="text-gray-600 text-sm">Visualización IA desde foto + texto</p>
					</div>
					<div class="bg-white rounded-xl p-5 border border-gray-100">
						<p class="text-[#e4665c] text-xs font-bold mb-2">PRÓXIMAMENTE</p>
						<p class="text-gray-600 text-sm">Configuraciones avanzadas, estilos y outputs profesionales</p>
					</div>
					<div class="bg-white rounded-xl p-5 border border-gray-100">
						<p class="text-[#e4665c] text-xs font-bold mb-2">FUTURO</p>
						<p class="text-gray-600 text-sm">Conexión directa con proveedores y producción real</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="py-20 bg-[#1a1a2a] text-center px-4">
			<div class="max-w-xl mx-auto">
				<h2 class="text-2xl font-black text-white mb-4">Empieza a diseñar tu evento</h2>
				<p class="text-gray-400 text-sm mb-8">Cuéntanos tu idea y te enseñamos cómo llevarla a la realidad.</p>
				<a href="/contacto" class="bg-[#e4665c] hover:bg-[#d86259] text-white px-10 py-3.5 rounded-full font-bold inline-block transition-all text-sm">
					Describe tu evento →
				</a>
			</div>
		</section>

		<Footer />
	</main>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getAllArtists, getArtistBySlug } from '../../sanity/queries';

export async function getStaticPaths() {
  const artists = await getAllArtists();
  return artists.map((artist: any) => ({
    params: { slug: artist.slug },
  }));
}

const { slug } = Astro.params;
const artist = await getArtistBySlug(slug!);
if (!artist) return Astro.redirect('/');

const desc = (artist.description || '');
const avatar = artist.avatar || '';
const images = (artist.images || []).map((i: any) => i.url).filter(Boolean);
const links = artist.links || {};

const platformConfig: Record<string, { label: string; color: string }> = {
  spotify: { label: 'Spotify', color: '#1DB954' },
  youtube: { label: 'YouTube', color: '#FF0000' },
  soundcloud: { label: 'SoundCloud', color: '#FF5500' },
  instagram: { label: 'Instagram', color: '#E4405F' },
  ra: { label: 'Resident Advisor', color: '#000000' },
  web: { label: 'Web', color: '#333333' },
};
---

<Layout title={`${artist.name} - MyGloven`}>
  <Navbar currentPage="/artistas" />
  <main class="max-w-4xl mx-auto px-4 pt-20 pb-8">
    <a href="/artistas" class="text-[#e4665c] hover:text-[#d86259] text-sm mb-8 inline-block">← Volver a artistas</a>

    <div class="flex flex-col md:flex-row items-start gap-8 mb-10">
      <div class="w-40 h-40 md:w-52 md:h-52 rounded-full overflow-hidden border-4 border-[#e4665c]/30 flex-shrink-0 mx-auto md:mx-0 shadow-xl">
        <img src={avatar || 'https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=400'} alt={artist.name} class="w-full h-full object-cover" />
      </div>
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-3xl md:text-4xl font-black text-[#1a1a2a] mb-3">{artist.name}</h1>
        {artist.email && (
          <a href={`mailto:${artist.email}`} class="text-gray-400 text-sm hover:text-[#e4665c] block mb-6">✉️ {artist.email}</a>
        )}
        
        {Object.entries(links).filter(([_, url]) => url).length > 0 && (
          <div class="flex flex-wrap gap-3 justify-center md:justify-start">
            {Object.entries(links).filter(([_, url]) => url).map(([platform, url]) => {
              const config = platformConfig[platform];
              if (!config) return null;
              return (
                <a 
                  href={url as string} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="flex items-center gap-2.5 px-5 py-3 rounded-full text-sm font-semibold text-white transition-all hover:scale-105 hover:shadow-lg"
                  style={`background-color: ${config.color}`}
                >
                  {config.label}
                </a>
              );
            })}
          </div>
        )}
      </div>
    </div>

    {images.length > 0 && (
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-10">
        {images.slice(0, 6).map((img: string) => (
          <img src={img} alt={artist.name} class="w-full h-48 object-cover rounded-xl" />
        ))}
      </div>
    )}

    {desc && (
      <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
        <h2 class="text-lg font-bold text-[#1a1a2a] mb-4">Sobre el artista</h2>
        <div class="text-gray-600 leading-relaxed whitespace-pre-line text-sm">{desc}</div>
      </div>
    )}
  </main>

  <Footer />
</Layout>

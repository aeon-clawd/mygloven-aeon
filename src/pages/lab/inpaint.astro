---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Inpaint Lab · mygloven">
	<main class="min-h-screen bg-[#1a1a2a] text-white">
		<div class="max-w-5xl mx-auto px-4 py-8">
			<div class="flex items-center gap-3 mb-8">
				<span class="text-2xl">🧪</span>
				<h1 class="text-2xl font-black">Inpaint Lab</h1>
				<span class="text-xs bg-[#e4665c]/20 text-[#e4665c] px-2 py-0.5 rounded-full">internal</span>
			</div>
			<div id="inpaint-app"></div>
		</div>
	</main>
	<script>
		import { createInpaintApp } from '../../components/InpaintCanvas';
		createInpaintApp(document.getElementById('inpaint-app')!);
	</script>
</Layout>

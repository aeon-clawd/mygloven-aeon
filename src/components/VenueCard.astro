---
import { getVenueCoverUrl, venueCapacityLabel, venueTagLabel, pad } from "../lib/queries";
import type { Venue } from "../lib/types";

interface Props {
  venue: Venue;
  index?: number;
}
const { venue, index = 0 } = Astro.props;

const positions = [
  { cx: "30%", cy: "40%" }, { cx: "70%", cy: "30%" }, { cx: "50%", cy: "60%" },
  { cx: "20%", cy: "70%" }, { cx: "80%", cy: "50%" }, { cx: "40%", cy: "30%" },
  { cx: "60%", cy: "70%" }, { cx: "30%", cy: "50%" },
];
const p = positions[index % positions.length];
const cover = getVenueCoverUrl(venue);
const capacity = venueCapacityLabel(venue);
const tag = venueTagLabel(venue);
const num = pad(index + 1);
const desc = venue.descripcion_corta || venue.descripcion || "";
const cityLabel = [venue.ciudad?.trim(), venue.pais?.trim()].filter(Boolean).join(", ");
---
<a class="venue-card" href={`/espacios/${venue.slug}`} data-cursor="ver →">
  <div class="ph" style={`--cx: ${p.cx}; --cy: ${p.cy};`}>
    {cover && <img src={cover} alt={venue.nombre} loading="lazy" />}
    <span class="stamp">№ {num}</span>
    <span class="tag">{tag}</span>
    {capacity && <span class="pax">{capacity}</span>}
  </div>
  <div class="body">
    <div class="city">— {cityLabel || "—"}</div>
    <h3>{venue.nombre}</h3>
    {desc && <p>{desc}</p>}
    <div class="foot">
      <span>VER FICHA</span>
      <span class="arrow">→</span>
    </div>
  </div>
</a>

---
import { SITE } from "../data/site";
---
<footer class="footer">
  <div class="footer-grid">
    <div>
      <div class="footer-brand">my<span class="ap">'</span>G<span class="ap">.</span></div>
      <p class="footer-tag">
        Agencia de booking, management y talento — Barcelona / Madrid. Operamos shows en España y Portugal desde 2019.
      </p>
    </div>
    <div class="footer-col">
      <h4>— Roster</h4>
      <ul>
        <li><a href="/artistas" data-cursor="artistas →">Todos los artistas</a></li>
        <li><a href="/artistas" data-cursor="djs →">DJs</a></li>
        <li><a href="/artistas" data-cursor="bandas →">Bandas en directo</a></li>
        <li><a href="/artistas" data-cursor="cuerda →">Cuerda y clásico</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>— Espacios</h4>
      <ul>
        <li><a href="/espacios" data-cursor="venues →">Todos los espacios</a></li>
        <li><a href="/espacios" data-cursor="bcn →">Barcelona</a></li>
        <li><a href="/espacios" data-cursor="mad →">Madrid</a></li>
        <li><a href="/espacios" data-cursor="open air →">Open air</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>— Contacto</h4>
      <ul>
        <li><a href={`mailto:${SITE.contactEmail}`} data-cursor="email">{SITE.contactEmail}</a></li>
        <li><a href="/contacto" data-cursor="prensa">Prensa & partners</a></li>
        <li><a href="https://www.instagram.com/mygloven/" target="_blank" rel="noopener" data-cursor="instagram">Instagram</a></li>
        <li><a href="/planes" data-cursor="planes">Planes</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-base">
    <span>© MYGLOVEN 2026 — TODOS LOS DERECHOS RESERVADOS</span>
    <span>BCN · MAD · LIS</span>
    <span>v2.0 / INDUSTRIAL</span>
  </div>
</footer>

---
import { SITE } from "../data/site";
---
<footer class="footer">
  <div class="footer-grid">
    <div>
      <div class="footer-brand">my<span class="ap">'</span>G</div>
      <p class="footer-tag">
        {SITE.brandSuffix}. Espacios, artistas y proveedores en una sola plataforma — Barcelona / Madrid.
      </p>
    </div>
    <div class="footer-col">
      <h4>— Plataforma</h4>
      <ul>
        <li><a href="/espacios" data-cursor="espacios →">Espacios</a></li>
        <li><a href="/artistas" data-cursor="artistas →">Artistas</a></li>
        <li><a href="/proveedores" data-cursor="proveedores →">Proveedores</a></li>
        <li><a href="/space-studio" data-cursor="space studio →">Space Studio</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>— Empresa</h4>
      <ul>
        <li><a href="/agency" data-cursor="agency →">my'G agency</a></li>
        <li><a href="/planes" data-cursor="planes →">Planes</a></li>
        <li><a href="/contacto" data-cursor="contacto →">Contacto</a></li>
        <li><a href={SITE.instagram} target="_blank" rel="noopener" data-cursor="instagram →">Instagram</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>— Contacto</h4>
      <ul>
        <li><a href={`mailto:${SITE.contactEmail}`} data-cursor="email →">{SITE.contactEmail}</a></li>
        <li><a href={SITE.instagram} target="_blank" rel="noopener" data-cursor="ig →">{SITE.instagramHandle}</a></li>
        <li><a href="https://mygloven.com" data-cursor="web →">mygloven.com</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-base">
    <span>{SITE.footer.copyright}</span>
    <span>BCN · MAD</span>
    <a href={SITE.footer.poweredByUrl} target="_blank" rel="noopener" class="powered-by" data-cursor="aeon →">{SITE.footer.poweredBy}</a>
  </div>
</footer>
